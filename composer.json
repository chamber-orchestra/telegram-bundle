{
    "name": "chamber-orchestra/telegram-bundle",
    "type": "symfony-bundle",
    "description": "Symfony 8 bundle for building Telegram bots — attribute-based routing, filter system, view/keyboard DSL, async webhook processing with rate limiting",
    "license": "Apache-2.0",
    "require": {
        "php": "^8.5",
        "doctrine/orm": "^3.0",
        "symfony/framework-bundle": "8.0.*",
        "symfony/http-foundation": "8.0.*",
        "symfony/http-client": "8.0.*",
        "symfony/messenger": "8.0.*",
        "symfony/rate-limiter": "8.0.*",
        "symfony/twig-bundle": "8.0.*",
        "symfony/translation": "8.0.*",
        "chamber-orchestra/doctrine-extensions-bundle": "8.0.*",
        "chamber-orchestra/doctrine-clock-bundle": "8.0.*"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpstan/phpstan": "^2.0",
        "symfony/maker-bundle": "^1.60"
    },
    "suggest": {
        "symfony/maker-bundle": "Allows generating handler classes via make:telegram:handler"
    },
    "autoload": {
        "psr-4": {
            "ChamberOrchestra\\TelegramBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ChamberOrchestra\\TelegramBundle\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "config": {
        "sort-packages": true
    }
}
